# ============================================================
# CG Reports — Variables de Entorno
# Copiar como ".env" y completar los valores
# ============================================================

# Puerto del servidor local
PORT=3000

# ── Google OAuth2 ───────────────────────────────────────────
# Obtener desde: https://console.cloud.google.com
# APIs habilitadas: Drive API, Sheets API, Apps Script API
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# ── Google Sheets — IDs de los Spreadsheets ────────────────
# Obtener de la URL del Sheet: /spreadsheets/d/[ID]/edit
SHEETS_DAILY_ID=your_daily_sheet_id_here
SHEETS_HOURLY_ID=your_hourly_sheet_id_here

# ── Google Apps Script — IDs de los Scripts ────────────────
# Obtener desde: Apps Script Editor → Configuración del proyecto → ID del script
APPS_SCRIPT_DAILY_ID=your_daily_script_id_here
APPS_SCRIPT_HOURLY_ID=your_hourly_script_id_here

# ── Google Drive — Nombres de carpetas ─────────────────────
DRIVE_FOLDER_DAILY=Daily_Source
DRIVE_FOLDER_HOURLY=Hourly_Source

# ── URLs de las aplicaciones ────────────────────────────────
GHL_URL=https://app.gohighlevel.com
THREECX_URL=https://3cx.cg-suite.com

# ── Puppeteer ───────────────────────────────────────────────
# true = headless (sin ventana, para producción)
# false = visible (para debug o setup inicial)
PUPPETEER_HEADLESS=true

# ── Timezone ────────────────────────────────────────────────
# Ejemplo: America/New_York, America/Chicago, America/Los_Angeles
TZ=America/New_York
